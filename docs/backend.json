
{
  "entities": {
    "Team": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Team",
      "type": "object",
      "description": "Represents a Faustball team.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the team."
        },
        "name": {
          "type": "string",
          "description": "Name of the team."
        },
        "description": {
          "type": "string",
          "description": "A brief description of the team."
        },
        "ranking": {
          "type": "number",
          "description": "The current ranking of the team."
        }
      },
      "required": [
        "id",
        "name"
      ]
    },
    "Match": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Match",
      "type": "object",
      "description": "Represents a Faustball match between two teams.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the match."
        },
        "team1Id": {
          "type": "string",
          "description": "Reference to Team 1. (Relationship: Team 1:N Match)"
        },
        "team2Id": {
          "type": "string",
          "description": "Reference to Team 2. (Relationship: Team 1:N Match)"
        },
        "team1Score": {
          "type": "number",
          "description": "Score of Team 1 in the match."
        },
        "team2Score": {
          "type": "number",
          "description": "Score of Team 2 in the match."
        },
        "matchDate": {
          "type": "string",
          "description": "Date and time of the match.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "team1Id",
        "team2Id",
        "team1Score",
        "team2Score",
        "matchDate"
      ]
    },
    "Player": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Player",
      "type": "object",
      "description": "Represents a Faustball player.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the player."
        },
        "teamId": {
          "type": "string",
          "description": "Reference to the Team the player belongs to. (Relationship: Team 1:N Player)"
        },
        "name": {
          "type": "string",
          "description": "Name of the player."
        },
        "position": {
          "type": "string",
          "description": "The player's position in the team."
        },
        "dateOfBirth": {
          "type": "string",
          "description": "The player's date of birth",
          "format": "date"
        }
      },
      "required": [
        "id",
        "teamId",
        "name"
      ]
    },
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user profile for the application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the user profile."
        },
        "username": {
          "type": "string",
          "description": "Username of the user."
        },
        "email": {
          "type": "string",
          "description": "Email address of the user.",
          "format": "email"
        }
      },
      "required": [
        "id",
        "username",
        "email"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "User profiles, accessible only to the user. Uses path-based ownership."
    },
    "/teams/{teamId}": {
      "schema": { "$ref": "#/entities/Team" },
      "description": "Teams data. Publicly readable, but write access should be restricted to admins."
    },
    "/teams/{teamId}/players/{playerId}": {
      "schema": { "$ref": "#/entities/Player" },
      "description": "Players associated with a team. Requires the 'teamId' to ensure data integrity and easy querying."
    },
    "/matches/{matchId}": {
      "schema": { "$ref": "#/entities/Match" },
      "description": "Match data. Publicly readable, but write access should be restricted to admins."
    },
    "/roles_admin/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Admin roles. Existence of a document grants admin access."
    }
  }
}
