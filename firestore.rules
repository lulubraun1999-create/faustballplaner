/**
 * @fileoverview Firestore Security Rules for the application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user profiles
 * and public read access with owner-only writes for news articles.
 * Team cash transactions and penalties are only accessible for authenticated users.
 * Member profiles are publicly readable.
 *
 * Data Structure:
 * - /users/{userId}: Stores private user data, accessible only by the user.
 * - /members/{memberId}: Stores public-readable member profiles
 * - /groups/{groupId}: Stores group information.
 * - /news/{newsId}: Stores news articles, publicly readable, writable only by the article author.
 * - /team-cash-transactions/{transactionId}: Stores cash transactions, only accessible for authenticated users.
 * - /penalties/{penaltyId}: Stores predefined penalties, only accessible for authenticated users.
 *
 * Key Security Decisions:
 * - Users can only read and write their own user document.
 * - News articles are publicly readable.
 * - News articles can only be created, updated, or deleted by the author.
 * - Listing of user documents is disallowed.
 * - Team cash transactions and penalties are accessible for authenticated users.
 *
 * Denormalization for Authorization:
 * - News articles include `authorId` to simplify ownership checks on writes.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profiles.
     * @path /users/{userId}
     * @allow (create) User with ID 'user123' can create their own profile.
     * @allow (get) User with ID 'user123' can read their own profile.
     * @allow (update) User with ID 'user123' can update their own profile.
     * @allow (delete) User with ID 'user123' can delete their own profile.
     * @deny (create) User with ID 'user456' cannot create a profile for user 'user123'.
     * @deny (get) User with ID 'user456' cannot read the profile of user 'user123'.
     * @principle Enforces document ownership for user profiles.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

      /**
     * @description Controls access to member profiles.
     * @path /members/{memberId}
     * @allow (get) Any user can read a member profile.
     * @allow (list) Any user can list member profiles.
     * @deny (create) Only authenticated user can create member
     * @deny (update) Only authenticated user can update member
     * @deny (delete) Only authenticated user can delete member
     * @principle Member profiles are publicly readable, writable only by authenticated user.
     */
    match /members/{memberId} {
      allow get: if true;
      allow list: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    /**
     * @description Controls access to group documents.
     * @path /groups/{groupId}
     * @allow (get) Any user can read a group document.
     * @allow (list) Any user can list group documents.
     * @deny (create) Only authenticated user can create group
     * @deny (update) Only authenticated user can update group
     * @deny (delete) Only authenticated user can delete group
     * @principle Groups are publicly readable, writable only by authenticated user.
     */
    match /groups/{groupId} {
      allow get: if true;
      allow list: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    /**
     * @description Controls access to news articles.
     * @path /news/{newsId}
     * @allow (get) Any user can read a news article.
     * @allow (list) Any user can list news articles.
     * @allow (create) User with ID 'user123' can create a news article with authorId: 'user123'.
     * @allow (update) User with ID 'user123' can update a news article with authorId: 'user123'.
     * @allow (delete) User with ID 'user123' can delete a news article with authorId: 'user123'.
     * @deny (create) User with ID 'user456' cannot create a news article with authorId: 'user123'.
     * @deny (update) User with ID 'user456' cannot update a news article with authorId: 'user123'.
     * @deny (delete) User with ID 'user456' cannot delete a news article with authorId: 'user123'.
     * @principle News articles are publicly readable, writable only by the author.
     */
    match /news/{newsId} {
      function isAuthor(authorId) {
        return request.auth.uid == authorId;
      }

      allow get: if true;
      allow list: if true;
      allow create: if request.auth != null && request.resource.data.authorId == request.auth.uid;
      allow update: if request.auth != null && isAuthor(resource.data.authorId) && resource != null;
      allow delete: if request.auth != null && isAuthor(resource.data.authorId) && resource != null;
    }

    /**
     * @description Controls access to team cash transactions.
     * @path /team-cash-transactions/{transactionId}
     * @allow (get) Authenticated user can read transaction
     * @allow (list) Authenticated user can list transactions
     * @deny (create) Only authenticated user can create transaction
     * @deny (update) Only authenticated user can update transaction
     * @deny (delete) Only authenticated user can delete transaction
     * @principle Team cash transactions are only accessible for authenticated user.
     */
     match /team-cash-transactions/{transactionId} {
      allow get: if request.auth != null;
      allow list: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && resource != null;
      allow delete: if request.auth != null && resource != null;
    }

     /**
     * @description Controls access to predefined penalties.
     * @path /penalties/{penaltyId}
     * @allow (get) Authenticated user can read penalty
     * @allow (list) Authenticated user can list penalties
     * @deny (create) Only authenticated user can create penalty
     * @deny (update) Only authenticated user can update penalty
     * @deny (delete) Only authenticated user can delete penalty
     * @principle Predefined penalties are only accessible for authenticated user.
     */
     match /penalties/{penaltyId} {
      allow get: if request.auth != null;
      allow list: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && resource != null;
      allow delete: if request.auth != null && resource != null;
    }
  }
}