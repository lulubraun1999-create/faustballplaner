/**
 * @fileoverview Firestore Security Rules for the Faustball App.
 *
 * Core Philosophy:
 * This ruleset enforces a strict ownership model for teams and their associated data (players, matches, cash registers).
 * Each team and its subcollections are accessible only to authenticated users.
 *
 * Data Structure:
 * - /teams/{teamId}: Contains team profiles.
 * - /teams/{teamId}/players/{playerId}: Contains player information for a specific team.
 * - /teams/{teamId}/matches/{matchId}: Contains match data for a specific team.
 * - /teams/{teamId}/mannschaftskasse/{mannschaftskasseId}: Contains the cash register for the team.
 *
 * Key Security Decisions:
 * - Authenticated access: All read and write operations require the user to be signed in.
 * - Ownership enforcement: Only authenticated users can manage teams, team members, matches, and cash registers.
 * - Immutable teamId: The `teamId` field in subcollections is immutable after creation to maintain data integrity.
 *
 * Denormalization for Authorization:
 * The `teamId` is used as the key to the team document and the `teamId` field in subcollections. This simplifies authorization checks,
 * avoiding the need for `get()` calls to verify ownership.
 *
 * Structural Segregation:
 * The app uses nested collections for teams, players, matches, and cash registers.
 * This allows for clear ownership and easier rule management.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows access to team documents.
     * @path /teams/{teamId}
     * @allow (get, list) if isSignedIn()
     * @allow (create) if isSignedIn() && request.resource.data.id == request.auth.uid
     * @allow (update, delete) if isSignedIn() && resource.data.id == request.auth.uid
     * @deny (create) if !isSignedIn()
     * @deny (update, delete) if !isSignedIn()
     * @principle Enforces team ownership for writes.
     */
    match /teams/{teamId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.id == teamId;
      allow update, delete: if isSignedIn() && resource.data.id == teamId;
    }

    /**
     * @description Allows access to player documents within a team.
     * @path /teams/{teamId}/players/{playerId}
     * @allow (get, list) if isSignedIn()
     * @allow (create) if isSignedIn() && request.resource.data.teamId == teamId
     * @allow (update, delete) if isSignedIn() && resource.data.teamId == teamId
     * @deny (create) if !isSignedIn() || request.resource.data.teamId != teamId
     * @deny (update, delete) if !isSignedIn() || resource.data.teamId != teamId
     * @principle Enforces team ownership for writes, validates teamId on create and update, and enforces immutability of teamId.
     */
    match /teams/{teamId}/players/{playerId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.teamId == teamId;
      allow update, delete: if isSignedIn() && resource.data.teamId == teamId;
    }

    /**
     * @description Allows access to match documents within a team.
     * @path /teams/{teamId}/matches/{matchId}
     * @allow (get, list) if isSignedIn()
     * @allow (create) if isSignedIn() && request.resource.data.team1Id == teamId || request.resource.data.team2Id == teamId
     * @allow (update, delete) if isSignedIn() && (resource.data.team1Id == teamId || resource.data.team2Id == teamId)
     * @deny (create) if !isSignedIn() || (request.resource.data.team1Id != teamId && request.resource.data.team2Id != teamId)
     * @deny (update, delete) if !isSignedIn() || (resource.data.team1Id != teamId && resource.data.team2Id != teamId)
     * @principle Enforces team ownership for writes, validates teamId on create and update, and enforces immutability of teamId.
     */
    match /teams/{teamId}/matches/{matchId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && (request.resource.data.team1Id == teamId || request.resource.data.team2Id == teamId);
      allow update, delete: if isSignedIn() && (resource.data.team1Id == teamId || resource.data.team2Id == teamId);
    }

    /**
     * @description Allows access to Mannschaftskasse documents within a team.
     * @path /teams/{teamId}/mannschaftskasse/{mannschaftskasseId}
     * @allow (get, list) if isSignedIn()
     * @allow (create) if isSignedIn() && request.resource.data.teamId == teamId
     * @allow (update, delete) if isSignedIn() && resource.data.teamId == teamId
     * @deny (create) if !isSignedIn() || request.resource.data.teamId != teamId
     * @deny (update, delete) if !isSignedIn() || resource.data.teamId != teamId
     * @principle Enforces team ownership for writes, validates teamId on create and update, and enforces immutability of teamId.
     */
    match /teams/{teamId}/mannschaftskasse/{mannschaftskasseId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.teamId == teamId;
      allow update, delete: if isSignedIn() && resource.data.teamId == teamId;
    }

    function isSignedIn() {
      return request.auth != null;
    }
  }
}