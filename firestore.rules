/**
 * @description This ruleset enforces a strict access control model for a Faustball application, focusing on team, player, and match data.
 * @dataStructure
 *   - Teams are stored in the `/teams/{teamId}` collection.
 *   - Players are stored in the `/teams/{teamId}/players/{playerId}` subcollection, with `teamId` denormalized into each player document.
 *   - Matches are stored in the `/matches/{matchId}` collection.
 * @keySecurityDecisions
 *   - Only authenticated users can create, update, or delete teams, players or matches.
 *   - List access is only allowed for players within a team's subcollection, accessible only to the team owner.
 *   - The rules explicitly deny listing of teams or matches to prevent unauthorized data exposure.
 * @denormalizationForAuthorization
 *   - The `Player` entity contains a denormalized `teamId` to allow direct validation of team membership without additional `get()` calls.
 * @structuralSegregation
 *   - Each entity type (Team, Player, Match) is stored in its own collection to simplify security management.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to team documents. Only authenticated users can create, update, or delete teams.
     * @path /teams/{teamId}
     * @allow (create) - An authenticated user can create a team.
     *   Example: `request.auth.uid != null`
     * @allow (update) - An authenticated user can update a team.
     *   Example: `request.auth.uid != null`
     * @allow (delete) - An authenticated user can delete a team.
     *   Example: `request.auth.uid != null`
     * @deny (create) - An unauthenticated user attempts to create a team.
     *   Example: `request.auth.uid == null`
     * @deny (update) - An unauthenticated user attempts to update a team.
     *   Example: `request.auth.uid == null`
     * @deny (delete) - An unauthenticated user attempts to delete a team.
     *   Example: `request.auth.uid == null`
     * @principle Enforces authentication for all write operations on teams.
     */
    match /teams/{teamId} {
      allow get: if true;
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Controls access to player documents within a team. Ensures that players belong to the specified team.
     * @path /teams/{teamId}/players/{playerId}
     * @allow (create) - An authenticated user can create a player within a team.
     *   Example: `request.auth.uid != null && request.resource.data.teamId == teamId`
     * @allow (update) - An authenticated user can update a player within a team.
     *   Example: `request.auth.uid != null && request.resource.data.teamId == resource.data.teamId`
     * @allow (delete) - An authenticated user can delete a player within a team.
     *   Example: `request.auth.uid != null && resource.data.teamId == teamId`
     * @deny (create) - An unauthenticated user attempts to create a player.
     *   Example: `request.auth.uid == null`
     * @deny (create) - An authenticated user attempts to create a player with a mismatched team ID.
     *   Example: `request.resource.data.teamId != teamId`
     * @deny (update) - An unauthenticated user attempts to update a player.
     *   Example: `request.auth.uid == null`
     * @principle Enforces authentication and validates team membership for player operations.
     */
    match /teams/{teamId}/players/{playerId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && request.resource.data.teamId == teamId;
      allow update: if isSignedIn() && resource != null && request.resource.data.teamId == resource.data.teamId;
      allow delete: if isSignedIn() && resource != null && resource.data.teamId == teamId;
    }

    /**
     * @description Controls access to match documents. Only authenticated users can create, update, or delete matches.
     * @path /matches/{matchId}
     * @allow (create) - An authenticated user can create a match.
     *   Example: `request.auth.uid != null`
     * @allow (update) - An authenticated user can update a match.
     *   Example: `request.auth.uid != null`
     * @allow (delete) - An authenticated user can delete a match.
     *   Example: `request.auth.uid != null`
     * @deny (create) - An unauthenticated user attempts to create a match.
     *   Example: `request.auth.uid == null`
     * @deny (update) - An unauthenticated user attempts to update a match.
     *   Example: `request.auth.uid == null`
     * @deny (delete) - An unauthenticated user attempts to delete a match.
     *   Example: `request.auth.uid == null`
     * @principle Enforces authentication for all write operations on matches.
     */
    match /matches/{matchId} {
      allow get: if true;
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }
  }

  function isSignedIn() {
    return request.auth != null;
  }
}