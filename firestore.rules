/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a hierarchical security model for a Faustball application, focusing on team, player, match, and cash register data.
 *
 * Core Philosophy:
 *  - Strict path-based ownership is enforced for most data, with granular control over read and write access.
 *  - Data is organized to minimize the need for complex `get()` operations in the rules, improving performance and security.
 *
 * Data Structure:
 *  - Teams are stored in the `/teams/{teamId}` collection.
 *  - Players are nested under their respective teams in `/teams/{teamId}/players/{playerId}`.
 *  - Matches are nested under their respective teams in `/teams/{teamId}/matches/{matchId}`.
 *  - Cash registers are under groups in `/groups/{groupId}/cashRegister/{cashRegisterId}`.
 *  - Transactions are nested under cash registers in `/groups/{groupId}/cashRegister/{cashRegisterId}/transactions/{transactionId}`.
 *
 * Key Security Decisions:
 *  - Public listing of teams, players, matches, cash registers and transactions is disallowed for all users.
 *  - The rules prioritize data integrity by enforcing ownership and validating relationships between entities.
 *  - The rules don't enforce the schema of the data being written, but they do enforce who can access what.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Secures the `teams` collection, allowing read access to all and write access only to authenticated users.
     * @path /teams/{teamId}
     * @allow (get) Authenticated user can retrieve a team.
     * @deny (list) No one can list teams.
     * @allow (create) Authenticated user can create a team. The id property is validated to match the teamId.
     * @allow (update) Authenticated user can update a team.
     * @allow (delete) Authenticated user can delete a team.
     * @deny (create) Unauthenticated user cannot create a team.
     * @principle Enforces document ownership for writes and allows public reads.
     */
    match /teams/{teamId} {
      allow get: if true;
      allow list: if false;

      allow create: if isSignedIn() && request.resource.data.id == teamId;
      allow update: if isSignedIn() && resource.data.id == teamId;
      allow delete: if isSignedIn() && resource.data.id == teamId && resource != null;

      function isSignedIn() {
        return request.auth != null;
      }
    }

    /**
     * @description Secures the `players` subcollection, allowing read and write access only to authenticated users associated with the parent team.
     * @path /teams/{teamId}/players/{playerId}
     * @allow (get) Authenticated user can retrieve a player in a team if the team exists.
     * @deny (list) No one can list players.
     * @allow (create) Authenticated user can create a player. The teamId property is validated to match the teamId.
     * @allow (update) Authenticated user can update a player. The teamId property must remain immutable.
     * @allow (delete) Authenticated user can delete a player.
     * @deny (create) Unauthenticated user cannot create a player.
     * @deny (create) Authenticated user cannot create a player with a mismatched teamId.
     * @principle Enforces document ownership for writes and allows public reads.
     */
    match /teams/{teamId}/players/{playerId} {
      allow get: if isSignedIn();
      allow list: if false;

      allow create: if isSignedIn() && request.resource.data.teamId == teamId;
      allow update: if isSignedIn() && resource.data.teamId == teamId;
      allow delete: if isSignedIn() && resource.data.teamId == teamId && resource != null;

      function isSignedIn() {
        return request.auth != null;
      }
    }

    /**
     * @description Secures the `matches` subcollection, allowing read and write access only to authenticated users associated with the parent team.
     * @path /teams/{teamId}/matches/{matchId}
     * @allow (get) Authenticated user can retrieve a match in a team if the team exists.
     * @deny (list) No one can list matches.
     * @allow (create) Authenticated user can create a match. The teamId property is validated to match the teamId.
     * @allow (update) Authenticated user can update a match. The teamId property must remain immutable.
     * @allow (delete) Authenticated user can delete a match.
     * @deny (create) Unauthenticated user cannot create a match.
     * @deny (create) Authenticated user cannot create a match with a mismatched teamId.
     * @principle Enforces document ownership for writes and allows public reads.
     */
    match /teams/{teamId}/matches/{matchId} {
      allow get: if isSignedIn();
      allow list: if false;

      allow create: if isSignedIn() && request.resource.data.team1Id == teamId || request.resource.data.team2Id == teamId;
      allow update: if isSignedIn() && (resource.data.team1Id == teamId || resource.data.team2Id == teamId);
      allow delete: if isSignedIn() && (resource.data.team1Id == teamId || resource.data.team2Id == teamId) && resource != null;

      function isSignedIn() {
        return request.auth != null;
      }
    }

    /**
     * @description Secures the `cashRegister` subcollection, allowing read and write access only to authenticated users associated with the parent group.
     * @path /groups/{groupId}/cashRegister/{cashRegisterId}
     * @allow (get) Authenticated user can retrieve a cash register in a group if the group exists.
     * @deny (list) No one can list cash registers.
     * @allow (create) Authenticated user can create a cash register. The groupId property is validated to match the groupId.
     * @allow (update) Authenticated user can update a cash register. The groupId property must remain immutable.
     * @allow (delete) Authenticated user can delete a cash register.
     * @deny (create) Unauthenticated user cannot create a cash register.
     * @deny (create) Authenticated user cannot create a cash register with a mismatched groupId.
     * @principle Enforces document ownership for writes and allows public reads.
     */
    match /groups/{groupId}/cashRegister/{cashRegisterId} {
      allow get: if isSignedIn();
      allow list: if false;

      allow create: if isSignedIn() && request.resource.data.groupId == groupId;
      allow update: if isSignedIn() && resource.data.groupId == groupId;
      allow delete: if isSignedIn() && resource.data.groupId == groupId && resource != null;

      function isSignedIn() {
        return request.auth != null;
      }
    }

    /**
     * @description Secures the `transactions` subcollection, allowing read and write access only to authenticated users associated with the parent cash register.
     * @path /groups/{groupId}/cashRegister/{cashRegisterId}/transactions/{transactionId}
     * @allow (get) Authenticated user can retrieve a transaction in a cash register if the cash register exists.
     * @deny (list) No one can list transactions.
     * @allow (create) Authenticated user can create a transaction.
     * @allow (update) Authenticated user can update a transaction.
     * @allow (delete) Authenticated user can delete a transaction.
     * @deny (create) Unauthenticated user cannot create a transaction.
     * @principle Enforces document ownership for writes and allows public reads.
     */
    match /groups/{groupId}/cashRegister/{cashRegisterId}/transactions/{transactionId} {
      allow get: if isSignedIn();
      allow list: if false;

      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && resource != null;

      function isSignedIn() {
        return request.auth != null;
      }
    }
  }
}