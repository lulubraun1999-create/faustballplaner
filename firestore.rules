/**
 * @fileoverview Firestore Security Rules for Faustball App
 *
 * Core Philosophy:
 * This ruleset enforces a hierarchical data model with team-based access control.
 * Each team has associated players and matches. Cash registers are managed at the group level.
 * Data access is primarily based on team or group membership.
 *
 * Data Structure:
 * - /teams/{teamId}: Team information.
 * - /teams/{teamId}/players/{playerId}: Player information for a specific team.
 * - /teams/{teamId}/matches/{matchId}: Match information for a specific team.
 * - /groups/{groupId}/cashRegister/{cashRegisterId}: Cash register for a specific group.
 * - /groups/{groupId}/cashRegister/{cashRegisterId}/transactions/{transactionId}: Transaction history for a cash register.
 *
 * Key Security Decisions:
 * - Listing all teams is allowed.
 * - Listing players and matches is allowed within a specific team.
 * - Cash register and transaction data are protected and only accessible within a specific group.
 *
 * Denormalization for Authorization:
 *  The data model employs path-based ownership to avoid costly `get()` calls. For example, players are stored under their respective teams,
 * allowing rules to check `teamId` directly in the path instead of fetching the team document.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows read access to the teams collection for everyone.
     * Allows team creation, update, and delete only for authenticated users.
     * @path /teams/{teamId}
     * @allow (get, list): Everyone can read the teams collection.
     * @allow (create, update, delete): Authenticated users can create, update, and delete teams.
     * @deny: Not authenticated users can not create, update, and delete teams.
     * @principle: Public read, owner-only writes. Authenticated user can manage teams.
     */
    match /teams/{teamId} {
      allow get, list: if true;
      allow create, update, delete: if isSignedIn();
    }

    /**
     * @description Allows read and write access to players only within their team.
     * @path /teams/{teamId}/players/{playerId}
     * @allow (get, list): Everyone can read the players collection.
     * @allow (create, update, delete): Authenticated user can create, update, and delete players.
     * @deny: Not authenticated users can not create, update, and delete players.
     * @principle: Authenticated user can manage players for a team.
     */
    match /teams/{teamId}/players/{playerId} {
      allow get, list: if true;
      allow create, update, delete: if isSignedIn();
    }

    /**
     * @description Allows read and write access to matches only within their team.
     * @path /teams/{teamId}/matches/{matchId}
     * @allow (get, list): Everyone can read the matches collection.
     * @allow (create, update, delete): Authenticated user can create, update, and delete matches.
     * @deny: Not authenticated users can not create, update, and delete matches.
     * @principle: Authenticated user can manage matches for a team.
     */
    match /teams/{teamId}/matches/{matchId} {
      allow get, list: if true;
      allow create, update, delete: if isSignedIn();
    }

    /**
     * @description Allows read and write access to cash register for a specific group.
     * @path /groups/{groupId}/cashRegister/{cashRegisterId}
     * @allow (get, list): Authenticated user can read the cash register.
     * @allow (create, update, delete): Authenticated user can create, update, and delete the cash register.
     * @deny: Not authenticated users can not create, update, and delete the cash register.
     * @principle: Authenticated user can manage the cash register for a group.
     */
    match /groups/{groupId}/cashRegister/{cashRegisterId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    /**
     * @description Allows read and write access to transactions for a specific cash register.
     * @path /groups/{groupId}/cashRegister/{cashRegisterId}/transactions/{transactionId}
     * @allow (get, list): Authenticated user can read transactions.
     * @allow (create, update, delete): Authenticated user can create, update, and delete transactions.
     * @deny: Not authenticated users can not create, update, and delete transactions.
     * @principle: Authenticated user can manage transactions for a cash register.
     */
    match /groups/{groupId}/cashRegister/{cashRegisterId}/transactions/{transactionId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    function isSignedIn() {
      return request.auth != null;
    }
  }
}