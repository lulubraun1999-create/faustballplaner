/**
 * @fileoverview Firestore Security Rules for the Faustball App.
 *
 * Core Philosophy:
 * This ruleset enforces a hierarchical data model with path-based ownership for teams and groups.
 * All write operations are strictly controlled based on user authentication and resource ownership.
 *
 * Data Structure:
 * - /teams/{teamId}: Collection of Faustball teams.
 * - /teams/{teamId}/players/{playerId}: Subcollection of players for a specific team.
 * - /teams/{teamId}/matches/{matchId}: Subcollection of matches for a specific team.
 * - /groups/{groupId}/cashRegister/{cashRegisterId}: Cash registers for groups.
 * - /groups/{groupId}/cashRegister/{cashRegisterId}/transactions/{transactionId}: Transactions for a specific cash register.
 * - /users/{userId}: User root document.
 *
 * Key Security Decisions:
 * - Users can only read and write their own user documents.
 * - Teams, players, and matches are secured based on team ownership.
 * - Cash Registers and Transactions are secured based on group ownership.
 * - Data validation is minimal in this prototyping phase.
 *
 * Denormalization for Authorization:
 * The data model relies on path-based authorization, so it does not require denormalization.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the user is signed in.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the user is the owner of the resource.
     */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * @description Checks if the user is the owner of an existing resource.
     * @principle Ensures that updates and deletes only happen on existing resources.
     */
    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }

    /**
     * @description Grants the owner full access to their own user document.
     * @path /users/{userId}
     * @allow (get) User with UID 'LClvhdr2OkWxkDpnOPNT0DKGwtC3' can read their own profile data.
     * @deny (get) User with UID 'otherUser' cannot read the profile data of user 'LClvhdr2OkWxkDpnOPNT0DKGwtC3'.
     * @principle Enforces user-level data privacy, preventing unauthorized access to user profiles.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Manages teams. Allows anyone to read a team; only allows creating, updating and deleting team if you are signed in.
     * @path /teams/{teamId}
     * @allow (get) Any user can read a team's information.
     * @deny (create) Anonymous users cannot create new teams.
     * @principle Allows public read access for teams, but enforces authentication for creation, updates and deletion.
     */
    match /teams/{teamId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Manages players within a team.  Allows anyone to read a player; only allows creating, updating and deleting team if you are signed in.
     * @path /teams/{teamId}/players/{playerId}
     * @allow (get) Any user can read a player's information.
     * @deny (create) Anonymous users cannot create new players.
     * @principle Allows public read access for players, but enforces authentication for creation, updates and deletion.
     */
    match /teams/{teamId}/players/{playerId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Manages matches within a team.  Allows anyone to read a match; only allows creating, updating and deleting team if you are signed in.
     * @path /teams/{teamId}/matches/{matchId}
     * @allow (get) Any user can read a match's information.
     * @deny (create) Anonymous users cannot create new matches.
     * @principle Allows public read access for matches, but enforces authentication for creation, updates and deletion.
     */
    match /teams/{teamId}/matches/{matchId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Manages Cash Registers within a group.  Allows anyone to read a Cash Register; only allows creating, updating and deleting team if you are signed in.
     * @path /groups/{groupId}/cashRegister/{cashRegisterId}
     * @allow (get) Any user can read a cash register's information.
     * @deny (create) Anonymous users cannot create new cash registers.
     * @principle Allows public read access for cash registers, but enforces authentication for creation, updates and deletion.
     */
    match /groups/{groupId}/cashRegister/{cashRegisterId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Manages Transactions within a Cash Register.  Allows anyone to read a Transaction; only allows creating, updating and deleting team if you are signed in.
     * @path /groups/{groupId}/cashRegister/{cashRegisterId}/transactions/{transactionId}
     * @allow (get) Any user can read a transaction's information.
     * @deny (create) Anonymous users cannot create new transactions.
     * @principle Allows public read access for transactions, but enforces authentication for creation, updates and deletion.
     */
    match /groups/{groupId}/cashRegister/{cashRegisterId}/transactions/{transactionId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }
  }
}