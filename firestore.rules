/**
 * @fileoverview Firestore Security Rules for Faustball App
 *
 * Core Philosophy:
 * This ruleset enforces a hierarchical data model with path-based ownership for teams, players, matches and cash registers.  It prioritizes Authorization Independence by avoiding `get()` calls in security rules.
 *
 * Data Structure:
 * - `/teams/{teamId}`: Stores team data.
 * - `/teams/{teamId}/players/{playerId}`: Stores player data associated with a team.
 * - `/teams/{teamId}/matches/{matchId}`: Stores match data associated with a team.
 * - `/groups/{groupId}/cashRegister/{cashRegisterId}`: Stores cash register data associated with a group.
 * - `/groups/{groupId}/cashRegister/{cashRegisterId}/transactions/{transactionId}`: Stores transactions associated with a cash register.
 *
 * Key Security Decisions:
 * - Data access is primarily controlled through path-based rules, leveraging the hierarchical structure of Firestore.
 * - List operations are secured based on the collection's data model, ensuring only authorized users can list documents.
 * - All write operations are protected by authorization checks to prevent unauthorized data modification.
 *
 * Denormalization for Authorization:
 *  - The `teamId` field is present on the `Player` and `Match` entities, enabling direct association with a `Team` document without additional `get()` calls.
 *  - The `groupId` field is present on the `CashRegister` entity, enabling direct association with a `Group` document without additional `get()` calls.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Rules for the /teams/{teamId} collection.
     * @path /teams/{teamId}
     * @allow (get, list): Any user can read team data.
     * @allow (create): Only signed in users can create teams.
     * @allow (update): Only signed in users can update teams.
     * @allow (delete): Only signed in users can delete teams.
     * @principle Public read, no writes allowed in this prototype.
     */
    match /teams/{teamId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Rules for the /teams/{teamId}/players/{playerId} collection.
     * @path /teams/{teamId}/players/{playerId}
     * @allow (get, list): Any user can read player data.
     * @allow (create): Only signed in users can create players.
     * @allow (update): Only signed in users can update players.
     * @allow (delete): Only signed in users can delete players.
     * @principle Public read, no writes allowed in this prototype.
     */
    match /teams/{teamId}/players/{playerId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Rules for the /teams/{teamId}/matches/{matchId} collection.
     * @path /teams/{teamId}/matches/{matchId}
     * @allow (get, list): Any user can read match data.
     * @allow (create): Only signed in users can create matches.
     * @allow (update): Only signed in users can update matches.
     * @allow (delete): Only signed in users can delete matches.
     * @principle Public read, no writes allowed in this prototype.
     */
    match /teams/{teamId}/matches/{matchId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Rules for the /groups/{groupId}/cashRegister/{cashRegisterId} collection.
     * @path /groups/{groupId}/cashRegister/{cashRegisterId}
     * @allow (get, list): Any user can read cash register data.
     * @allow (create): Only signed in users can create cash registers.
     * @allow (update): Only signed in users can update cash registers.
     * @allow (delete): Only signed in users can delete cash registers.
     * @principle Public read, no writes allowed in this prototype.
     */
    match /groups/{groupId}/cashRegister/{cashRegisterId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Rules for the /groups/{groupId}/cashRegister/{cashRegisterId}/transactions/{transactionId} collection.
     * @path /groups/{groupId}/cashRegister/{cashRegisterId}/transactions/{transactionId}
     * @allow (get, list): Any user can read transaction data.
     * @allow (create): Only signed in users can create transactions.
     * @allow (update): Only signed in users can update transactions.
     * @allow (delete): Only signed in users can delete transactions.
     * @principle Public read, no writes allowed in this prototype.
     */
    match /groups/{groupId}/cashRegister/{cashRegisterId}/transactions/{transactionId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    function isSignedIn() {
      return request.auth != null;
    }
  }
}