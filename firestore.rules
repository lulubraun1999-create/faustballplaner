rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.adminRechte == true;
    }

    function isMemberOfGroup(groupId) {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.groupIds.hasAny([groupId]);
    }

    // Collection rules
    match /users/{userId} {
      allow read: if isAuth();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /members/{memberId} {
        allow read: if isAuth();
        allow write: if isAdmin();
    }

    match /groups/{groupId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    
    match /news/{articleId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    match /team-cash-transactions/{transactionId} {
      // Allow any authenticated user to read all transactions.
      allow read: if isAuth();
      allow write: if isAdmin() || isMemberOfGroup(request.resource.data.groupId);
    }
    
    match /penalties/{penaltyId} {
      allow read: if isAuth();
      allow write: if isAdmin() || isMemberOfGroup(request.resource.data.groupId);
    }
  }
}
