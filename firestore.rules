/**
 * @file Firestore Security Rules
 * @version 2
 *
 * @description
 * This ruleset enforces a strict data model where teams, players, and matches
 * are stored in separate top-level collections. It ensures that only
 * authenticated users can create, modify, or delete data, with specific
 * ownership constraints enforced for each collection.
 *
 * @dataStructure
 * - /teams/{teamId}: Stores team information.
 * - /teams/{teamId}/players/{playerId}: Stores player information associated with a team. The 'teamId' is denormalized onto each player document for efficient authorization.
 * - /matches/{matchId}: Stores match information, including references to two teams.
 *
 * @keySecurityDecisions
 * - Authenticated users are required for all write operations.
 * - Teams and Matches can be created by any authenticated user. Updates and deletes are disallowed.
 * - Players are nested under teams, with write access restricted to authenticated users.
 * - Data validation is limited to ensuring path consistency and preventing modification of key relational fields after creation.
 * - Listing of teams and matches is publicly available.
 * - Listing of players within a team is available to authenticated users.
 *
 * @denormalizationForAuthorization
 * - The 'teamId' is denormalized into the 'Player' document. This allows for verifying the relationship between a player and a team without requiring additional reads in the security rules.
 *
 * @structuralSegregation
 * - Teams, Players, and Matches are stored in separate top-level collections to maintain a homogeneous security posture within each collection.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to the 'teams' collection.
     * @path /teams/{teamId}
     * @allow (get, list): Any user can read team data.
     * @allow (create): Any authenticated user can create a team.
     * @deny (update, delete): No user can update or delete a team.
     * @principle Allows public read access with restricted write access.
     */
    match /teams/{teamId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    /**
     * @description Controls access to the 'players' subcollection within a specific team.
     * @path /teams/{teamId}/players/{playerId}
     * @allow (get, list): Any authenticated user can read player data for a team.
     * @allow (create): Any authenticated user can create a player. The teamId on the player document must match the teamId in the path.
     * @deny (update, delete): No user can update or delete a player.
     * @principle Enforces ownership for writes and requires the teamId on the document to match the path.
     */
    match /teams/{teamId}/players/{playerId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.teamId == teamId;
      allow update, delete: if false;
    }

    /**
     * @description Controls access to the 'matches' collection.
     * @path /matches/{matchId}
     * @allow (get, list): Any user can read match data.
     * @allow (create): Any authenticated user can create a match.
     * @deny (update, delete): No user can update or delete a match.
     * @principle Allows public read access with restricted write access.
     */
    match /matches/{matchId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    /**
     * @description Checks if the request is authenticated.
     * @return {bool} True if the request is authenticated; otherwise, false.
     */
    function isSignedIn() {
      return request.auth != null;
    }
  }
}