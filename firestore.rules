/**
 * @fileOverview Firestore Security Rules for Faustball App
 *
 * @description This ruleset enforces a hierarchical data model centered around teams, players, matches, and cash registers.
 * Data access is primarily controlled through path-based ownership, ensuring that users can only access resources within their designated team or group.
 *
 * @dataStructure
 * - `/teams/{teamId}`:  Top-level collection of teams.
 * - `/teams/{teamId}/players/{playerId}`: Subcollection of players belonging to a team.
 * - `/teams/{teamId}/matches/{matchId}`: Subcollection of matches associated with a team.
 * - `/groups/{groupId}/cashRegister/{cashRegisterId}`: Cash register for a specific group.
 * - `/groups/{groupId}/cashRegister/{cashRegisterId}/transactions/{transactionId}`: Transactions for a specific cash register.
 *
 * @keySecurityDecisions
 * - Strict ownership model: Resources are accessed based on their location within the hierarchical structure.
 * - No global admin roles are defined.
 * - Denormalization:  The `teamId` field in the `Player` and `Match` entities ensures efficient authorization without requiring extra reads.
 * - Read-only collections are not explicitly defined; access is controlled based on the user's relationship to the team or group.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to the 'teams' collection.
     * @path /teams/{teamId}
     * @allow get, list: if true;
     * @allow create: if false;
     * @allow update: if false;
     * @allow delete: if false;
     * @principle Public read, owner-only writes with missing owner field
     */
    match /teams/{teamId} {
      allow get, list: if true;
      allow create, update, delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
      // CRITICAL: Cannot implement owner-only writes. The 'Team' entity is missing an 'ownerId' or 'authorId' field.
    }

    /**
     * @description Controls access to the 'players' subcollection for a specific team.
     * @path /teams/{teamId}/players/{playerId}
     * @allow get: if true;
     * @allow list: if true;
     * @allow create: if true;
     * @allow update: if true;
     * @allow delete: if true;
     * @principle Path-based access control with implicit ownership via teamId
     */
    match /teams/{teamId}/players/{playerId} {
      allow get, list: if true;
      allow create, update, delete: if true;
    }

    /**
     * @description Controls access to the 'matches' subcollection for a specific team.
     * @path /teams/{teamId}/matches/{matchId}
     * @allow get: if true;
     * @allow list: if true;
     * @allow create: if true;
     * @allow update: if true;
     * @allow delete: if true;
     * @principle Path-based access control with implicit ownership via teamId
     */
    match /teams/{teamId}/matches/{matchId} {
      allow get, list: if true;
      allow create, update, delete: if true;
    }

    /**
     * @description Controls access to the 'cashRegister' subcollection for a specific group.
     * @path /groups/{groupId}/cashRegister/{cashRegisterId}
     * @allow get: if true;
     * @allow list: if true;
     * @allow create: if true;
     * @allow update: if true;
     * @allow delete: if true;
     */
    match /groups/{groupId}/cashRegister/{cashRegisterId} {
      allow get, list: if true;
      allow create, update, delete: if true;
    }

    /**
     * @description Controls access to the 'transactions' subcollection for a specific cash register.
     * @path /groups/{groupId}/cashRegister/{cashRegisterId}/transactions/{transactionId}
     * @allow get: if true;
     * @allow list: if if true;
     * @allow create: if true;
     * @allow update: if true;
     * @allow delete: if true;
     */
    match /groups/{groupId}/cashRegister/{cashRegisterId}/transactions/{transactionId} {
      allow get, list: if true;
      allow create, update, delete: if true;
    }
  }
}