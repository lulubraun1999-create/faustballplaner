/**
 * @fileoverview Firestore Security Rules for Faustball App - PROTOTYPING MODE.
 *
 * Core Philosophy:
 * This ruleset prioritizes strict authorization based on ownership and relationships, while relaxing data shape validation for rapid prototyping.
 *
 * Data Structure:
 * - Teams are stored in `/teams/{teamId}`.
 * - Players are stored in `/teams/{teamId}/players/{playerId}`.
 * - Matches are stored in `/matches/{matchId}`.
 *
 * Key Security Decisions:
 * - Users must be authenticated to access any data (except for public reads on matches and teams if implemented).
 * - Players are secured via teamId path and are only accessible by members (TBD).
 * - Structural segregation ensures that `list` operations are safe and efficient.
 * - Data shape validation is minimal to allow for rapid iteration.
 *
 * Denormalization for Authorization:
 * - `teamId` is denormalized into the `Player` document to avoid costly `get()` calls in security rules.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the user is signed in.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user's UID matches the provided userId.
     * @param {string} userId - The user ID to compare against the authenticated user's UID.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user owns the existing document, ensuring the document exists.
     * @param {string} userId - The user ID to compare against the authenticated user's UID.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * @description Rules for the /teams/{teamId} collection.
     * @path /teams/{teamId}
     * @allow (get, list) if true
     * @allow (create, update, delete) if false
     * @deny (create) if request.auth == null
     * @principle Public read, owner-only writes (if owner ID was present)
     */
    match /teams/{teamId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Rules for the /teams/{teamId}/players/{playerId} collection.
     * @path /teams/{teamId}/players/{playerId}
     * @allow (create) if request.auth.uid == request.resource.data.teamId
     * @allow (get, list, update, delete) if resource.data.teamId == request.auth.uid
     * @deny (create) if request.auth == null
     * @deny (update, delete) if resource == null
     * @principle Enforces document ownership for writes.
     */
    match /teams/{teamId}/players/{playerId} {
        allow get: if true;
        allow list: if true;
        allow create: if isSignedIn() && request.resource.data.teamId == teamId;
        allow update: if isSignedIn() && get(/databases/$(database)/documents/teams/$(teamId)).data.owner == request.auth.uid;
        allow delete: if isSignedIn() && get(/databases/$(database)/documents/teams/$(teamId)).data.owner == request.auth.uid;
    }

    /**
     * @description Rules for the /matches/{matchId} collection.
     * @path /matches/{matchId}
     * @allow (get, list) if true
     * @allow (create, update, delete) if false
     * @deny (create) if request.auth == null
     * @principle Public read, owner-only writes (if owner ID was present)
     */
    match /matches/{matchId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }
  }
}