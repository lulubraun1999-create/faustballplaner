rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Rules for the 'teams' collection.
     * @path /teams/{teamId}
     * @allow (get, list): Any user can read team information.
     * @allow (create, update, delete): Only signed in users can create.
     * @principle Public read-only collection for teams.
     */
    match /teams/{teamId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    /**
     * @description Rules for the 'players' subcollection within a team.
     * @path /teams/{teamId}/players/{playerId}
     * @allow (get, list): Any user can read players of a team.
     * @allow create: if isSignedIn();
     * @allow update, delete: if false;
     * @principle Public read-only collection for players, based on team membership.
     */
    match /teams/{teamId}/players/{playerId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    /**
     * @description Rules for the 'matches' collection.
     * @path /matches/{matchId}
     * @allow (get, list): Any user can read matches information.
     * @allow (create): Only signed in users can create matches.
     * @allow update, delete: if false;
     * @principle Public read-only collection for matches.
     */
    match /matches/{matchId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    /**
     * @description Checks if the user is signed in.
     * @return {boolean} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }
  }
}