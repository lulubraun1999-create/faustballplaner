/**
 * @fileoverview Firestore Security Rules for Faustball App
 *
 * Core Philosophy:
 * This ruleset enforces a hierarchical data model with path-based authorization.
 * Each data type (teams, players, matches, cash registers, transactions) is stored in its own collection.
 * Authorization is based on path ownership, meaning a user (or team) can only access data nested under their specific ID.
 * This design avoids complex `get()` calls in rules, leading to efficient and scalable security checks.
 *
 * Data Structure:
 * - /teams/{teamId}: Teams collection.
 * - /teams/{teamId}/players/{playerId}: Players subcollection for each team.
 * - /teams/{teamId}/matches/{matchId}: Matches subcollection for each team.
 * - /groups/{groupId}/cashRegister/{cashRegisterId}: Cash register for each group
 * - /groups/{groupId}/cashRegister/{cashRegisterId}/transactions/{transactionId}: Transactions subcollection for each cash register.
 *
 * Key Security Decisions:
 * - Listing teams, players, matches, cash registers, and transactions is only allowed for the owner (team/group) of the path.
 * - All writes are restricted to the owner of the parent document.
 * - The rules do not validate the data types or presence of fields, focusing instead on authorization and path consistency.
 *
 * Denormalization for Authorization:
 * The 'teamId' field is used in /teams/{teamId}/players/{playerId} and /teams/{teamId}/matches/{matchId} to
 * associate the player/match with the team and simplify authorization checks.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Defines if the current user is signed in.
     * @return {boolean} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Defines if the current user is the owner of the resource based on the provided userId.
     * @param {string} userId - The user ID to compare against the authenticated user's ID.
     * @return {boolean} True if the user is the owner, false otherwise.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Defines if the current user is the existing owner of the resource based on the provided userId.
     * @param {string} userId - The user ID to compare against the authenticated user's ID.
     * @return {boolean} True if the user is the owner, false otherwise.
     */
    function isExistingOwner(userId) {
        return isSignedIn() && request.auth.uid == userId && resource != null;
    }

    /**
     * @description Security rules for the /teams/{teamId} collection.
     * @path /teams/{teamId}
     * @allow (create) - Authenticated user can create a team if the team id matches the request id.
     * @allow (get, list) - Any user can read teams.
     * @deny (update, delete) - Only the owner (same user who created it) can modify the team.
     * @deny (create) - If the userId does not match the auth.uid.
     * @principle Enforces ownership for team documents.
     */
    match /teams/{teamId} {
      allow get, list: if true;
      allow create: if isOwner(teamId) && request.resource.data.id == teamId;
      allow update: if isExistingOwner(teamId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(teamId);
    }

    /**
     * @description Security rules for the /teams/{teamId}/players/{playerId} collection.
     * @path /teams/{teamId}/players/{playerId}
     * @allow (create) - Authenticated user can create a player if the team id matches the parent and the player id matches the request id.
     * @allow (get, list) - Only the team can read the players.
     * @deny (update, delete) - Only the team can modify the player.
     * @deny (create) - If the userId does not match the auth.uid.
     * @principle Enforces ownership for player documents.
     */
    match /teams/{teamId}/players/{playerId} {
      allow get, list: if isOwner(teamId);
      allow create: if isOwner(teamId) && request.resource.data.teamId == teamId && request.resource.data.id == playerId;
      allow update: if isExistingOwner(teamId) && request.resource.data.teamId == resource.data.teamId && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(teamId);
    }

    /**
     * @description Security rules for the /teams/{teamId}/matches/{matchId} collection.
     * @path /teams/{teamId}/matches/{matchId}
     * @allow (create) - Authenticated user can create a match if the team id matches the parent and the match id matches the request id.
     * @allow (get, list) - Only the team can read the matches.
     * @deny (update, delete) - Only the team can modify the match.
     * @deny (create) - If the userId does not match the auth.uid.
     * @principle Enforces ownership for match documents.
     */
    match /teams/{teamId}/matches/{matchId} {
      allow get, list: if isOwner(teamId);
      allow create: if isOwner(teamId) && request.resource.data.team1Id == teamId && request.resource.data.id == matchId;
      allow update: if isExistingOwner(teamId) && request.resource.data.team1Id == resource.data.team1Id && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(teamId);
    }

    /**
     * @description Security rules for the /groups/{groupId}/cashRegister/{cashRegisterId} collection.
     * @path /groups/{groupId}/cashRegister/{cashRegisterId}
     * @allow (create) - Authenticated user can create a cash register if the group id matches the parent and the cashRegister id matches the request id.
     * @allow (get, list) - Only the team can read the cash register.
     * @deny (update, delete) - Only the team can modify the cash register.
     * @deny (create) - If the userId does not match the auth.uid.
     * @principle Enforces ownership for cash register documents.
     */
    match /groups/{groupId}/cashRegister/{cashRegisterId} {
        allow get, list: if isOwner(groupId);
        allow create: if isOwner(groupId) && request.resource.data.groupId == groupId;
        allow update: if isExistingOwner(groupId) && request.resource.data.groupId == resource.data.groupId;
        allow delete: if isExistingOwner(groupId);
    }

      /**
       * @description Security rules for the /groups/{groupId}/cashRegister/{cashRegisterId}/transactions/{transactionId} collection.
       * @path /groups/{groupId}/cashRegister/{cashRegisterId}/transactions/{transactionId}
       * @allow (create) - Authenticated user can create a transaction if the group id matches the parent and the transaction id matches the request id.
       * @allow (get, list) - Only the team can read the transactions.
       * @deny (update, delete) - Only the team can modify the transaction.
       * @deny (create) - If the userId does not match the auth.uid.
       * @principle Enforces ownership for transaction documents.
       */
    match /groups/{groupId}/cashRegister/{cashRegisterId}/transactions/{transactionId} {
      allow get, list: if isOwner(groupId);
      allow create: if isOwner(groupId);
      allow update: if isExistingOwner(groupId);
      allow delete: if isExistingOwner(groupId);
    }
  }
}