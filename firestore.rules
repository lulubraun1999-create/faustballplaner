rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.adminRechte == true;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isMemberOfGroup(groupId) {
      return exists(/databases/$(database)/documents/members/$(request.auth.uid)) && get(/databases/$(database)/documents/members/$(request.auth.uid)).data.groupIds.hasAny([groupId]);
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /members/{memberId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    
    match /groups/{groupId} {
        allow read: if isAuth();
        allow create, update, delete: if isAdmin();
    }

    match /news/{articleId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }
    
    match /surveys/{surveyId} {
      allow read: if isAuth();
      allow create, delete: if isAdmin();
      // Allow updates only for voting, not changing the structure
      allow update: if isAuth() && request.resource.data.keys().hasOnly(['options']);
      
      match /responses/{responseId} {
          allow read, create, delete: if isAuth() && (isOwner(responseId) || isAdmin());
      }
    }

    match /team-cash-transactions/{transactionId} {
      // Any authenticated user can read all transactions
      allow read: if isAuth();
      // Only admins or members of the group can create/update/delete
      allow create, update, delete: if isAdmin() || (isAuth() && isMemberOfGroup(request.resource.data.groupId));
    }
    
    match /penalties/{penaltyId} {
        allow read: if isAuth();
        allow create, update, delete: if isAdmin() || (isAuth() && isMemberOfGroup(request.resource.data.groupId));
    }
  }
}
