/**
 * @fileoverview Firestore Security Rules for Faustball Team Management.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user profiles,
 * and path-based authorization for teams, players, and matches. All reads
 * and writes are restricted to authorized users. The rules are designed
 * to prevent unauthorized access and ensure data integrity.
 *
 * Data Structure:
 * - /teams/{teamId}: Collection of Faustball teams.
 * - /teams/{teamId}/players/{playerId}: Subcollection of players for a specific team.
 * - /teams/{teamId}/matches/{matchId}: Subcollection of matches for a specific team.
 * - /groups/{groupId}/cashRegister/{cashRegisterId}: Represents the cash register for a specific group.
 * - /groups/{groupId}/cashRegister/{cashRegisterId}/transactions/{transactionId}: Represents the transactions for a specific cash register.
 * - /users/{userId}: Collection of user profiles.
 *
 * Key Security Decisions:
 * - User profiles are private and accessible only to the authenticated user.
 * - Teams, Players, and Matches are accessible based on team ownership.
 * - Listing of user profiles is denied to prevent information disclosure.
 * - Write operations on all collections require authentication.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the request is made by an authenticated user.
     * @path N/A
     * @allow N/A
     * @deny N/A
     * @principle Requires authentication for all operations.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user ID matches the provided user ID.
     * @path N/A
     * @allow N/A
     * @deny N/A
     * @principle Enforces user-specific ownership.
     */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user is the owner and the resource exists.
     * @path N/A
     * @allow N/A
     * @deny N/A
     * @principle Enforces existence and user-specific ownership.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * @description Rules for the /teams/{teamId} collection.
     * @path /teams/{teamId}
     * @allow if true (get, list) - Anyone can read team information.
     * @allow if isSignedIn() (create) - An authenticated user can create a new team.
     * @deny if !isSignedIn() (update, delete) - Only an authenticated user can update or delete a team.
     * @deny if true - Prevents unauthorized modifications and deletions.
     * @principle Public read, owner-only writes.
     */
    match /teams/{teamId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Rules for the /teams/{teamId}/players/{playerId} collection.
     * @path /teams/{teamId}/players/{playerId}
     * @allow if true (get, list) - Anyone can read player information.
     * @allow if isSignedIn() (create) - An authenticated user can create a new player.
     * @deny if !isSignedIn() (update, delete) - Only an authenticated user can update or delete a player.
     * @deny if true - Prevents unauthorized modifications and deletions.
     * @principle Public read, owner-only writes (assuming team ownership implies player management rights).
     */
    match /teams/{teamId}/players/{playerId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Rules for the /teams/{teamId}/matches/{matchId} collection.
     * @path /teams/{teamId}/matches/{matchId}
     * @allow if true (get, list) - Anyone can read match information.
     * @allow if isSignedIn() (create) - An authenticated user can create a new match.
     * @deny if !isSignedIn() (update, delete) - Only an authenticated user can update or delete a match.
     * @deny if true - Prevents unauthorized modifications and deletions.
     * @principle Public read, owner-only writes (assuming team ownership implies match management rights).
     */
    match /teams/{teamId}/matches/{matchId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Rules for the /groups/{groupId}/cashRegister/{cashRegisterId} collection.
     * @path /groups/{groupId}/cashRegister/{cashRegisterId}
     * @allow get, list: if isSignedIn();
     * @allow create: if isSignedIn();
     * @deny update: if true;
     * @deny delete: if true;
     * @principle Requires authentication for all operations, no write access granted.
     */
    match /groups/{groupId}/cashRegister/{cashRegisterId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Rules for the /groups/{groupId}/cashRegister/{cashRegisterId}/transactions/{transactionId} collection.
     * @path /groups/{groupId}/cashRegister/{cashRegisterId}/transactions/{transactionId}
     *  @allow get, list: if isSignedIn();
     *  @allow create: if isSignedIn();
     *  @deny update: if true;
     *  @deny delete: if true;
     * @principle Requires authentication for all operations, no write access granted.
     */
    match /groups/{groupId}/cashRegister/{cashRegisterId}/transactions/{transactionId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Rules for the /users/{userId} collection.
     * @path /users/{userId}
     * @allow get: if isOwner(userId); - Only the user can get their own profile.
     * @deny list: if true; - Listing users is not allowed.
     * @allow create: if isOwner(userId); - Only the user can create their own profile.
     * @allow update: if isExistingOwner(userId); - Only the user can update their own profile.
     * @allow delete: if isExistingOwner(userId); - Only the user can delete their own profile.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }
  }
}