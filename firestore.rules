/**
 * @file Overview
 * This ruleset enforces a strict data ownership model, primarily focused on teams and their associated players.
 *
 * Data Structure:
 * - /teams/{teamId}: Stores team information.
 * - /teams/{teamId}/players/{playerId}: Stores player information, nested under teams.
 * - /matches/{matchId}: Stores match information.
 *
 * Key Security Decisions:
 * - Users do not have individual accounts; authorization is not user-based.
 * - Instead, anyone can read public team or match data.
 * - Create, Update, and Delete permissions are disabled due to the lack of user authentication.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to team documents.
     * @path /teams/{teamId}
     * @allow (get, list) Anyone can read team data.
     * @deny (create, update, delete) No one can create, update, or delete teams.
     * @principle Public read, no writes allowed.
     */
    match /teams/{teamId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Controls access to player documents within a team.
     * @path /teams/{teamId}/players/{playerId}
     * @allow (get, list) Anyone can read player data.
     * @deny (create, update, delete) No one can create, update, or delete players.
     * @principle Public read, no writes allowed.
     */
    match /teams/{teamId}/players/{playerId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Controls access to match documents.
     * @path /matches/{matchId}
     * @allow (get, list) Anyone can read match data.
     * @deny (create, update, delete) No one can create, update, or delete matches.
     * @principle Public read, no writes allowed.
     */
    match /matches/{matchId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }
  }
}