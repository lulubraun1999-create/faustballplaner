/**
 * @fileoverview Firestore Security Rules for Faustball Team Management.
 *
 * Core Philosophy:
 * This ruleset implements a hierarchical data model with team-centric organization.
 * Access is primarily based on team ownership.
 *
 * Data Structure:
 * - /teams/{teamId}: Contains team profile information.
 * - /teams/{teamId}/players/{playerId}: Contains player information related to a specific team.
 * - /teams/{teamId}/matches/{matchId}: Contains match information for a specific team.
 * - /groups/{groupId}/cashRegister/{cashRegisterId}: Contains the cash register of a group.
 * - /groups/{groupId}/cashRegister/{cashRegisterId}/transactions/{transactionId}: Contains the transactions of a cash register.
 *
 * Key Security Decisions:
 * - All writes are validated against authenticated user IDs.
 * - Data validation focuses on authorization-critical fields (e.g., teamId, groupId).
 * - List operations are secured based on ownership.
 * - The rules enforce authorization independence.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Grants access to team data.
     * @path /teams/{teamId}
     * @allow (get, list): Public read access for all teams.
     * @allow (create): Allowed if the user is authenticated.
     * @allow (update, delete): Allowed if the user is authenticated.
     * @deny (create, update, delete): Denied if the user is not authenticated.
     * @principle Public read, authenticated write.
     */
    match /teams/{teamId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    /**
     * @description Grants access to player data within a team.
     * @path /teams/{teamId}/players/{playerId}
     * @allow (get, list): Allowed if the user is authenticated.
     * @allow (create): Allowed if the user is authenticated.
     * @allow (update, delete): Allowed if the user is authenticated.
     * @deny (create, update, delete): Denied if the user is not authenticated.
     * @principle Authenticated access to player data within a team.
     */
    match /teams/{teamId}/players/{playerId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    /**
     * @description Grants access to match data within a team.
     * @path /teams/{teamId}/matches/{matchId}
     * @allow (get, list): Allowed if the user is authenticated.
     * @allow (create): Allowed if the user is authenticated.
     * @allow (update, delete): Allowed if the user is authenticated.
     * @deny (create, update, delete): Denied if the user is not authenticated.
     * @principle Authenticated access to match data within a team.
     */
    match /teams/{teamId}/matches/{matchId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    /**
     * @description Grants access to cash register data for a group.
     * @path /groups/{groupId}/cashRegister/{cashRegisterId}
     * @allow (get, list): Allowed if the user is authenticated.
     * @allow (create): Allowed if the user is authenticated.
     * @allow (update, delete): Allowed if the user is authenticated.
     * @deny (create, update, delete): Denied if the user is not authenticated.
     * @principle Authenticated access to cash register data for a group.
     */
    match /groups/{groupId}/cashRegister/{cashRegisterId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    /**
     * @description Grants access to transaction data for a cash register.
     * @path /groups/{groupId}/cashRegister/{cashRegisterId}/transactions/{transactionId}
     * @allow (get, list): Allowed if the user is authenticated.
     * @allow (create): Allowed if the user is authenticated.
     * @allow (update, delete): Allowed if the user is authenticated.
     * @deny (create, update, delete): Denied if the user is not authenticated.
     * @principle Authenticated access to transaction data for a cash register.
     */
    match /groups/{groupId}/cashRegister/{cashRegisterId}/transactions/{transactionId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    function isSignedIn() {
        return request.auth != null;
    }
  }
}