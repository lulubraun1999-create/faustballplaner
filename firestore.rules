rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthed() {
      return request.auth != null;
    }

    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.adminRechte == true;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // USERS
    match /users/{userId} {
      allow read;
      allow write: if isOwner(userId) || isAdmin();
    }
    
    // MEMBERS (publicly readable member profiles)
    match /members/{memberId} {
      allow read;
      allow write: if isAdmin();
    }
    
    // GROUPS
    match /groups/{groupId} {
        allow read;
        allow create, update, delete: if isAdmin();
    }
    
    // NEWS
    match /news/{articleId} {
        allow read;
        allow create, update, delete: if isAdmin();
    }
    
    // SURVEYS
    match /surveys/{surveyId} {
      allow read: if isAuthed();
      allow create, update, delete: if isAdmin();
      
      match /responses/{responseId} {
        allow read, create, delete: if isAuthed();
        // Disallow updates to prevent tampering
        allow update: if false;
      }
    }

    // TEAM-CASH-TRANSACTIONS
    match /team-cash-transactions/{transactionId} {
        allow read: if isAuthed();
        allow create, update, delete: if isAdmin();
    }
    
    // PENALTIES
    match /penalties/{penaltyId} {
        allow read: if isAuthed();
        allow create, update, delete: if isAdmin();
    }
  }
}
